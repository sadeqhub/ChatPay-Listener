{
  "name": "chatpay-listener",
  "version": "1.0.0",
  "description": "Wayl Instagram webhook listener (Meta → Postgres + BullMQ)",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=18 <23"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "build:web": "node scripts/generate-web-config.js",
    "deploy:web": "npm run build:web && netlify deploy --prod --dir=web",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.76.8",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "porter": "^0.0.8",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
