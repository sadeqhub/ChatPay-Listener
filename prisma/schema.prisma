  active  Boolean  @default(true)
  user    User     @relation(fields: [userId], references: [id])
  store   Store    @relation(fields: [storeId], references: [id])
}

model PaymentMethod {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  name                String
  publishedAt         DateTime?
  icon                String
  code                String    @unique
  supportsWebsite     Boolean   @default(true)
  supportsIntegration Boolean   @default(true)
}

enum PaymentMethodCodeEnum {
  Cards
  COD
  Amwal
  Switch
  Areeba
  QiCard
  Stripe
  ZainCash
  FastPay
  NassWallet
  Taif
  FIB
}

// Wallet

model MerchantWalletTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  type        WalletTransactionType
  amount      Decimal // + for increase, - for decrease
  description String?
  currency    String                @default("IQD")
  status      TransactionStatus     @default(confirmed)

  referenceType String? // e.g. "order", "payout", etc.
  referenceId   String? // ID of the related entity (order, payout, refund...)

  metadata Json?
  User     User?   @relation(fields: [userId], references: [id])
  userId   String?
}

enum WalletTransactionType {
  sale
  account_refill
  payout
  refund
  chargeback
  subscription_fee
  sales_commission
  payout_commission
  refund_commission
  chargeback_penalty
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

enum SourceEnum {
  api
  dashboard
  store
  subscription
  bot
}

model CardToken {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  token         String         @unique
  customer      Customer?      @relation(fields: [customerId], references: [id])
  customerId    String?
  last4digits   String?
  brand         CardBrand?
  subscriptions Subscription[]
  hash          String?
  expiry        String?
}

enum CardBrand {
  Visa
  Mastercard
  Amex
  Discover
  JCB
  UnionPay
  Maestro
  Diners
  Rupay
  Mir
  Unknown
  Raqeeem
}

model Subscription {
  id              String             @id @default(cuid())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  amount          Int
  currency        String             @default("IQD")
  period          SubscriptionPeriod
  productJson     Json
  customer        Customer?          @relation(fields: [customerId], references: [id])
  customerId      String?
  store           Store?             @relation(fields: [storeId], references: [id])
  storeId         String?
  product         Product?           @relation(fields: [productId], references: [id])
  productId       String?
  status          SubscriptionStatus @default(Active)
  nextBillingAt   DateTime?
  pendingAmount   Int                @default(0)
  unpaidSince     DateTime?
  retryCount      Int?               @default(0)
  cardToken       CardToken?         @relation(fields: [cardTokenId], references: [id])
  cardTokenId     String?
  cancelledAt     DateTime?
  cancelledBy     CancelledBy?
  cancelledReason String?
  referenceId     String?
}

enum CancelledBy {
  Customer
  Merchant
  Admin
  System
}

enum SubscriptionStatus {
  Active
  Cancelled
  Retrying
}

model SystemSettings {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  settings  Json     @default("{}")
}

model Attempt {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  orderId              String
  order                Order    @relation(fields: [orderId], references: [id])
  error                Json     @default("{}")
  paymentProcessor     String?
  gatewayTransactionID String?
  paymentResponse      Json     @default("{}")
  threeDSecureResponse Json     @default("{}")
  customer             Json     @default("{}")
  phonenumber          String?
  cardDetails          Json     @default("{}")
}

model WaylInvoice {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  paidAt    DateTime?

  amount      Int
  currency    String        @default("IQD")
  status      InvoiceStatus @default(Pending)
  paymentLink String?

  metadata    Json    @default("{}")
  description String?

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id])
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id])
}

enum InvoiceStatus {
  Pending
  Paid
  Failed
  Expired
}

model WaylSubscription {
  id              String                 @id @default(cuid())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  amount          Int
  currency        String                 @default("IQD")
  period          WaylSubscriptionPeriod
  productJson     Json
  store           Store?                 @relation(fields: [storeId], references: [id])
  storeId         String?
  status          WaylSubscriptionStatus @default(Active)
  nextBillingAt   DateTime?
  pendingAmount   Int                    @default(0)
  unpaidSince     DateTime?
  retryCount      Int?                   @default(0)
  cancelledAt     DateTime?
  cancelledBy     CancelledBy?
  cancelledReason String?
  referenceId     String?
}

enum WaylSubscriptionStatus {
  Active
  Cancelled
  Retrying
}

enum WaylSubscriptionPeriod {
  Weekly
  Monthly
  Yearly
}

enum WaylCancelledBy {
  Merchant
  Admin
  System
}

enum PayoutAccountMethod {
  FIB
  ZainCash
  QiCard
  RTGS
  WaylCard
  Cash
}

model PayoutAccount {
  id         String              @id @default(cuid())
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  method     PayoutAccountMethod @default(FIB)
  key        String
  holderName String
  active     Boolean             @default(true)
  archived   Boolean             @default(false)
  preferred  Boolean             @default(false)
  storeId    String
  userId     String
  store      Store               @relation(fields: [storeId], references: [id])
  user       User                @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  senderId    String
  recipientId String

  platform PlatformEnum @default(Instagram)
  messages Message[]
}

enum PlatformEnum {
  WhatsApp
  Instagram
  Facebook
  TikTok
  Youtube
  LinkedIn
  Twitter
  Pinterest
  Reddit
  Snapchat
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  senderId    String
  recipientId String

  messageId String
  text      String
  timestamp String

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
}

model ChannelAccount {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  accessToken String

  platform PlatformEnum
  externalAccountId String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([platform, externalAccountId])
}

model BotJobAudit {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  jobName        String
  conversationId String?
  input          Json     @default("{}")
  output         Json?
  error          String?
  durationMs     Int?
}
