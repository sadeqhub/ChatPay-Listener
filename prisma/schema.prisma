  inventories             Json[]
  images                  Json[]
  optionTemplate          Json[]
  userId                  String?
  tagId                   String?
  status                  String              @default("Visible")
  customFeilds            Json[]
  discountType            String              @default("%")
  discountExpiry          String?
  discountValue           String              @default("0")
  type                    ProductType         @default(Physical)
