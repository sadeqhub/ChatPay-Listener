  zaincashAccount              String?
  supportPhone                 String?
  phone                        String?
  iban                         String?
  facebookPixel                String?
  metaConverstionAPIToken      String?
  snapPixel                    String?
  tiktokPixel                  String?
  fees                         Json?
  policies                     Json?
  socialLinks                  Json?
  status                       String?
  timeline                     Json[]                      @default([])
  charity                      Boolean                     @default(false)
  verificationStatus           VerificationStatus          @default(NothingUploaded)
  address                      String?
  paymentProfileId             String?
  preferredPayoutMethod        PreferredPayoutMethod       @default(ZainCash)
