generator client {
  provider      = "prisma-client-js"
  engineType      = "library"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

// Dual-Schema Account model - supports both NextAuth and Better Auth

model Account {
  id     String @id @default(cuid())
  userId String

  // NextAuth columns (keep existing for backward compatibility)
  type               String?
  provider           String?
  providerAccountId  String?
  access_token       String?
  refresh_token      String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  // Better Auth columns (new)
  providerId            String?
  accountId             String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  idToken               String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Keep NextAuth unique constraint for backward compatibility
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Dual-Schema Session model - supports both NextAuth and Better Auth

model Session {
  id     String @id @default(cuid())
  userId String

  // NextAuth columns (keep existing for backward compatibility)
  sessionToken String?   @unique
  expires      DateTime?

  // Better Auth columns (new)
  token     String?   @unique
  expiresAt DateTime?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Dual-Schema User model - supports both NextAuth and Better Auth

model User {
  id    String  @id @default(cuid())
  name  String?
  email String? @unique
  image String?

  // NextAuth column (keep existing for backward compatibility)
  // DateTime when email was verified, null if not verified
  emailVerified DateTime?

  // Better Auth column (new)
  // Boolean flag for email verification status
  emailVerifiedBool Boolean @default(false)

  // Custom fields
  activeStore String?
  parent      String?

  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  accounts             Account[]
  kycForm              KYCForm?
  Order                Order[]
  Payout               Payout[]
  products             Product[]
  PromoCodes           PromoCodes[]
  Refund               Refund[]
  sessions             Session[]
  tags                 Tag[]
  Webhook              Webhook[]
  customers            Customer[]                  @relation("CustomerToUser")
  stores               Store[]                     @relation("StoreToUser")
  Integration          Integration[]
  MerchantTransactions MerchantWalletTransaction[]
  waylInvoice          WaylInvoice?
  payoutAccounts       PayoutAccount[]
  conversations        Conversation[]
  messages             Message[]
  channelAccounts      ChannelAccount[]
}

// NextAuth - VerificationToken model (keep existing for backward compatibility)

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// Better Auth - Verification model for email verification, magic links, OTP

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

